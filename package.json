  },
  "devDependencies": {
    "@effect/language-service": "0.80.0",
    "@types/bun": "1.3.10",
    "dprint": "0.53.0",
    "oxlint": "1.56.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": "1.3.10"
  },
  "packageManager": "bun@1.3.10"
